{#=====================================================
  Creature List page
=====================================================#}

{% extends 'pages/_base.jinja' %}


{% block content %}

    <h2>List of Creatures</h2>

    <form action="/search" method="get">
    
        <label>
            Search for...
            <input type="text" name="q">
        </label>

        <select name="species">
            <option value="">Any</option>

            {% for species in species_list %}
                <option>{{ species }}</option>
            {% endfor %}

        </select>

        <button>Search</button>

    </form>

    <section id="creatures">

        {% for creature in creatures %}

            <div class="creature">
                <h3>{{ creature.name }}</h3>
                <p>Species: <strong>{{ creature.species }}</strong></p>
            </div>

        {% else %}

            <p>No Creatures!</p>

        {% endfor %}

    </section>

{% endblock %}

